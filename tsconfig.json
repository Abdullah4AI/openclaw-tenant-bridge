{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["./*.ts", "./src/**/*.ts"],
  "exclude": [
    "./**/*.test.ts",
    "./dist/**",
    "./node_modules/**",
    "./src/test-support/**",
    "./src/**/*test-helpers.ts",
    "./src/**/*test-harness.ts",
    "./src/**/*test-support.ts"
  ]
}
